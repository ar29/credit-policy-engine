# ==========================================
# Prayaan Credit Policy Engine - Environment
# ==========================================
# Copy this file to .env and adjust values as needed.

# --- Application Environment ---
# Options: development, staging, production
APP_ENV=development
LOG_LEVEL=INFO

# --- Redis Configuration ---
# If running via Docker Compose, host is 'redis'. If running locally, use 'localhost'.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Temporal Configuration ---
# If running via Docker Compose, host is 'temporal:7233'. If locally, use 'localhost:7233'.
TEMPORAL_SERVER_URL=temporal:7233
TEMPORAL_TASK_QUEUE=policy-queue

# --- LLM / Ollama Configuration ---
# If running via Docker Compose, host is 'http://ollama:11434'.
OLLAMA_BASE_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=llama3.2:1b

# --- Data Volumes ---
POLICY_FILE_PATH=data/policy.txt